# Heemia App — variabili d'ambiente (Fase 11)
# Copia in .env e compila. I valori reali NON si committano e NON vanno nel vault Obsidian.

# --- Core ---
NODE_ENV=development
PORT=3001
APP_BASE_URL=http://localhost:3001
DATABASE_URL=postgresql://heemia:heemia@localhost:5432/heemia_dev
SESSION_SECRET=            # openssl rand -hex 32

# --- AI (FR-12/13/28) ---
ANTHROPIC_API_KEY=

# --- Shopify (DEC-009, sync bidirezionale) ---
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# --- Google (Gmail bozze DEC-028, Drive link DEC-010) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# --- Frontend (Vercel env, non secret) ---
VITE_API_BASE_URL=http://localhost:3001
