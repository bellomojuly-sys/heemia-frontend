# Backend Heemia (Fase 12). Copia in server/.env e compila. Valori reali mai nel repo/vault.
NODE_ENV=development
PORT=3001
APP_BASE_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173
# Postgres locale (docker compose up -d nella cartella 04_Claude_Code)
DATABASE_URL=postgresql://heemia:heemia@localhost:5432/heemia_dev
# openssl rand -hex 32
SESSION_SECRET=
SESSION_TTL_HOURS=12
# usato solo dal seed per creare il primo admin
SEED_ADMIN_EMAIL=admin@heemia.local
SEED_ADMIN_PASSWORD=
